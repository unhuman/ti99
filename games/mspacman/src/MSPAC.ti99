1111 CALL LINK("DELAY",1500)
1112 IF LV>0 THEN 1114
1113 GOSUB 1120 :: RETURN
1114 GX(1)=121 :: GY(1)=77 :: GX(2)=121 :: GY(2)=93 :: GX(3)=105 :: GY(3)=93 :: GX(4)=137 :: GY(4)=93
1115 FOR J=1 TO 4 :: GS(J)=0 :: GD(J)=4 :: CALL COLOR(#(J+1),GC(J)) :: CALL PATTERN(#(J+1),116) :: CALL LOCATE(#(J+1),GY(J),GX(J)) :: NEXT J
1116 SX=121 :: SY=141 :: DD=0 :: CD=4 :: HD=4 :: CALL LOCATE(#1,SY,SX) :: CALL PATTERN(#1,96)
1117 FT=0 :: EG=0 :: EC=0 :: FC=0 :: DG=0 :: GOSUB 708
1118 RETURN
