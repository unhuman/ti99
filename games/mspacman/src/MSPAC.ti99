300 CALL KEY(0,K,S) :: EA=0
301 IF K=69 THEN DD=1
302 IF K=83 THEN DD=3
303 IF K=68 THEN DD=4
304 IF K=88 THEN DD=2
305 IF K=81 THEN 600
