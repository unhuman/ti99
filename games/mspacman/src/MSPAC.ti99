1107 CALL PATTERN(#1,136) :: CALL SOUND(110,170,2) :: CALL SOUND(1,170,30)
1108 CALL PATTERN(#1,140) :: CALL SOUND(110,140,2) :: CALL SOUND(1,140,30)
1109 CALL PATTERN(#1,132) :: CALL SOUND(150,110,2) :: CALL SOUND(1,110,30)
