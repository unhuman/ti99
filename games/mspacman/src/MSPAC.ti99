100 REM ===========================================
101 REM  MS. PAC-MAN  (disk name: MSPAC)   -- STEP 1
102 REM  Sprite + coordinate foundation (12px art, 4px walls)
103 REM  XB256 + XB compiler.  See DESIGN.md / repo CLAUDE.md
104 REM  Quit: press Q
105 REM ===========================================
110 CALL LINK("SCRN2")
115 CALL SCREEN(2)
120 CALL CLEAR
125 REM --- maze tiles: 4px walls (set 13, blue) + dot (set 14, white) ---
126 CALL LINK("CHAR2",128,"0000FFFFFFFF0000")
127 CALL LINK("CHAR2",129,"3C3C3C3C3C3C3C3C")
128 CALL LINK("CHAR2",130,"00003F3F3F3F3C3C")
129 CALL LINK("CHAR2",131,"0000FCFCFCFC3C3C")
130 CALL LINK("CHAR2",132,"3C3C3F3F3F3F0000")
131 CALL LINK("CHAR2",133,"3C3CFCFCFCFC0000")
132 CALL LINK("CHAR2",136,"0000001818000000")
133 CALL LINK("COLOR2",13,6,1)
134 CALL LINK("COLOR2",14,16,1)
135 REM --- sprites: MAGNIFY(3), ~12px art centered in 16px box (2px transparent frame) ---
136 REM Ms Pac-Man (#1) chars 96-99
137 CALL CHAR(96,"0000071F3F3F3F3F3F3F3F3F1F0700000000E0F8FCF0C00000C0F0FCF8E00000")
138 REM Ghost (#2-#5) chars 100-103
139 CALL CHAR(100,"0000071F3F33333F3F3F3F3F3F3600000000E0F8FCCCCCFCFCFCFCFCFCD80000")
140 REM Fruit cherry (#6) chars 104-107
141 CALL CHAR(104,"0000000001070F1F1F1F0F0700000000000060C080C0E0F0F0F0E0C000000000")
142 CALL MAGNIFY(3)
145 REM --- outer border (4px wall tiles) ---
146 CALL HCHAR(2,2,128,30)
147 CALL HCHAR(23,2,128,30)
148 CALL VCHAR(3,1,129,20)
149 CALL VCHAR(3,32,129,20)
150 CALL HCHAR(2,1,130)
151 CALL HCHAR(2,32,131)
152 CALL HCHAR(23,1,132)
153 CALL HCHAR(23,32,133)
155 REM --- ghost pen (rows 10-12, cols 13-20; door gap at cols 16-17) ---
156 CALL HCHAR(10,14,128,2)
157 CALL HCHAR(10,18,128,2)
158 CALL HCHAR(12,14,128,6)
159 CALL HCHAR(11,13,129)
160 CALL HCHAR(11,20,129)
161 CALL HCHAR(10,13,130)
162 CALL HCHAR(10,20,131)
163 CALL HCHAR(12,13,132)
164 CALL HCHAR(12,20,133)
166 REM --- sample dots (white, one per cell) to show density + color split ---
167 CALL HCHAR(5,4,136,10)
168 CALL HCHAR(20,21,136,8)
175 REM --- sprites: Y=(R-1)*8-3 X=(C-1)*8-3 (TI coords 1-based); pen+Blinky at col 16.5 ---
176 CALL SPRITE(#1,96,11,133,117,0,0)
177 CALL SPRITE(#2,100,9,61,121,0,0)
178 CALL SPRITE(#3,100,14,77,105,0,0)
179 CALL SPRITE(#4,100,8,77,121,0,0)
180 CALL SPRITE(#5,100,10,77,137,0,0)
181 CALL SPRITE(#6,104,9,133,181,0,0)
185 DISPLAY AT(1,1):"MS PAC-MAN   STEP 2"
186 SX=117 :: SY=133 :: CD=0 :: DD=0
190 REM ===== STEP 2: player movement via LOCATE (E/S/D/X or joystick; Q quits) =====
300 CALL KEY(0,K,S)
301 IF K=69 THEN DD=1
302 IF K=83 THEN DD=3
303 IF K=68 THEN DD=4
304 IF K=88 THEN DD=2
305 IF K=81 THEN 600
306 CALL JOYST(1,JX,JY)
307 IF JY>0 THEN DD=1
308 IF JY<0 THEN DD=2
309 IF JX<0 THEN DD=3
310 IF JX>0 THEN DD=4
315 AX=SX+3 :: AY=SY+3
316 IF AX-INT(AX/8)*8<>0 THEN 400
317 IF AY-INT(AY/8)*8<>0 THEN 400
320 C=INT((SX+11)/8) :: R=INT((SY+11)/8)
325 TR=R :: TC=C
326 IF DD=1 THEN TR=R-1
327 IF DD=2 THEN TR=R+1
328 IF DD=3 THEN TC=C-1
329 IF DD=4 THEN TC=C+1
330 GOSUB 700
331 IF WL=0 AND DD<>0 THEN CD=DD :: GOTO 400
335 TR=R :: TC=C
336 IF CD=1 THEN TR=R-1
337 IF CD=2 THEN TR=R+1
338 IF CD=3 THEN TC=C-1
339 IF CD=4 THEN TC=C+1
340 IF CD=0 THEN 400
341 GOSUB 700
342 IF WL=1 THEN CD=0
400 IF CD=1 THEN SY=SY-2
401 IF CD=2 THEN SY=SY+2
402 IF CD=3 THEN SX=SX-2
403 IF CD=4 THEN SX=SX+2
420 CALL LOCATE(#1,SY,SX)
430 CALL LINK("DELAY",25)
440 GOTO 300
600 END
700 REM --- wall check: sets WL=1 if cell (TR,TC) is a wall tile (128-133) ---
701 IF TC<1 OR TC>32 THEN WL=1 :: RETURN
702 IF TR<1 OR TR>24 THEN WL=1 :: RETURN
703 CALL GCHAR(TR,TC,G) :: WL=0
704 IF G>127 AND G<134 THEN WL=1
705 RETURN
