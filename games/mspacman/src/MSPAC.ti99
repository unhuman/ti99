1140 GOSUB 1160 :: MZ=1 :: IF LE>=3 THEN MZ=2 :: IF LE>=6 THEN MZ=3 :: IF LE>=10 THEN MZ=4
1141 GOSUB 800 :: GX(1)=121 :: GY(1)=77 :: GX(2)=121 :: GY(2)=93 :: GX(3)=105 :: GY(3)=93 :: GX(4)=137 :: GY(4)=93
1142 FOR J=1 TO 4 :: GS(J)=0 :: GD(J)=4 :: CALL COLOR(#(J+1),GC(J)) :: CALL PATTERN(#(J+1),116) :: CALL LOCATE(#(J+1),GY(J),GX(J)) :: NEXT J
1143 SX=121 :: SY=141 :: DD=0 :: CD=4 :: HD=4 :: CALL LOCATE(#1,SY,SX) :: CALL PATTERN(#1,96)
1144 FT=0 :: EG=0 :: EC=0 :: FC=0 :: DG=0 :: FA=0 :: FN=0 :: MO=0 :: MT=280 :: GOSUB 708
1145 RETURN
