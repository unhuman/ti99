312 IF CD=2 AND DD=1 THEN CD=1 :: GOTO 315
313 IF CD=3 AND DD=4 THEN CD=4 :: GOTO 315
314 IF CD=4 AND DD=3 THEN CD=3 :: GOTO 315
315 FOR SS=1 TO 2 :: GOSUB 350 :: NEXT SS :: GOTO 411
350 REM --- 1px sub-step: centered=eat+square-turn+stop; else corner-cut jump (Ms.Pac edge) or straight 1px ---
351 AX=SX+3 :: AY=SY+3 :: XC=AX-INT(AX/8)*8 :: YC=AY-INT(AY/8)*8
352 IF XC=0 AND YC=0 THEN 360
353 GOTO 370
360 C=INT((SX+11)/8) :: R=INT((SY+11)/8) :: GOSUB 750
361 TR=R :: TC=C :: IF DD=1 THEN TR=R-1 ELSE IF DD=2 THEN TR=R+1 ELSE IF DD=3 THEN TC=C-1 ELSE IF DD=4 THEN TC=C+1
362 IF DD<>0 THEN GOSUB 700 :: IF WL=0 THEN CD=DD
363 TR=R :: TC=C :: IF CD=1 THEN TR=R-1 ELSE IF CD=2 THEN TR=R+1 ELSE IF CD=3 THEN TC=C-1 ELSE IF CD=4 THEN TC=C+1
364 IF CD<>0 THEN GOSUB 700 :: IF WL=1 THEN CD=0
365 GOTO 390
370 PRP=0 :: IF (CD=3 OR CD=4) AND (DD=1 OR DD=2) THEN PRP=1
371 IF (CD=1 OR CD=2) AND (DD=3 OR DD=4) THEN PRP=1
372 IF PRP=0 THEN 390
373 JD=8-XC :: IF CD=3 THEN JD=XC
374 IF CD=1 THEN JD=YC
375 IF CD=2 THEN JD=8-YC
376 IF JD<1 OR JD>2 THEN 390
377 SXC=SX :: SYC=SY :: IF CD=4 THEN SXC=SX+JD ELSE IF CD=3 THEN SXC=SX-JD ELSE IF CD=2 THEN SYC=SY+JD ELSE SYC=SY-JD
378 RC=INT((SYC+11)/8) :: CC=INT((SXC+11)/8) :: TR=RC :: TC=CC
379 IF DD=1 THEN TR=RC-1 ELSE IF DD=2 THEN TR=RC+1 ELSE IF DD=3 THEN TC=CC-1 ELSE TC=CC+1
380 GOSUB 700 :: IF WL=1 THEN 390
381 C=CC :: R=RC :: GOSUB 750 :: EA=0
382 IF CD=4 THEN SX=SX+JD ELSE IF CD=3 THEN SX=SX-JD ELSE IF CD=2 THEN SY=SY+JD ELSE SY=SY-JD
383 IF DD=1 THEN SY=SY-JD ELSE IF DD=2 THEN SY=SY+JD ELSE IF DD=3 THEN SX=SX-JD ELSE SX=SX+JD
384 CD=DD :: RETURN
390 IF EA=1 OR CD=0 THEN RETURN
391 IF CD=1 THEN SY=SY-1 ELSE IF CD=2 THEN SY=SY+1 ELSE IF CD=3 THEN SX=SX-1 ELSE IF CD=4 THEN SX=SX+1
392 RETURN
411 IF SX<13 THEN SX=229
412 IF SX>229 THEN SX=13
419 IF CD<>0 THEN HD=CD
420 CALL LOCATE(#1,SY,SX)
421 PP=96 :: IF HD=1 THEN PP=104 ELSE IF HD=2 THEN PP=108 ELSE IF HD=3 THEN PP=100
422 PR=INT((SY+11)/8) :: PC=INT((SX+11)/8)
423 IF CD<>0 AND FC-INT(FC/8)*8>=4 THEN PP=112 :: IF HD=3 THEN PP=120 ELSE IF HD=1 THEN PP=104
424 IF PP<>LP THEN CALL PATTERN(#1,PP) :: LP=PP
425 FOR GI=1 TO 4 :: GOSUB 999 :: NEXT GI
426 FOR GI=1 TO 4
427 DX=ABS(SX-GX(GI)) :: DY=ABS(SY-GY(GI))
428 IF DX+DY<8 THEN GOSUB 780
429 NEXT GI
430 CALL LINK("DELAY",25) :: IF PT>=1000 AND BG=0 THEN GOSUB 785
431 IF FC<30000 THEN FC=FC+1
