1130 REM --- level cleared: flash maze 4x, advance level, faster ghosts, shorter fright, new fruit, refill ---
1131 NX=0 :: LE=LE+1 :: IF FA=1 THEN CALL DELSPRITE(#6) :: FA=0
1132 FOR J=1 TO 4 :: CALL PATTERN(#(J+1),132) :: NEXT J
1133 FOR DR=1 TO 4
