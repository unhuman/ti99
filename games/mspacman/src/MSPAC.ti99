100 REM ===========================================
101 REM  MS. PAC-MAN  (disk name: MSPAC)   -- STEP 7 (lives/respawn)
102 REM  Data-driven maze (autotiled 4px walls) + per-maze color
103 REM  XB256 + XB compiler.  See DESIGN.md / repo CLAUDE.md
104 REM  Move: E/S/D/X or joystick.  Quit: Q
105 REM ===========================================
110 CALL LINK("SCRN2")
115 CALL SCREEN(2)
120 CALL CLEAR
125 REM --- 16 autotile wall tiles 128-143 (mask 0..15) ---
126 CALL LINK("CHAR2",128,"00003C3C3C3C0000")
127 CALL LINK("CHAR2",129,"3C3C3C3C3C3C0000")
128 CALL LINK("CHAR2",130,"00003F3F3F3F0000")
129 CALL LINK("CHAR2",131,"3C3C3F3F3F3F0000")
130 CALL LINK("CHAR2",132,"00003C3C3C3C3C3C")
131 CALL LINK("CHAR2",133,"3C3C3C3C3C3C3C3C")
132 CALL LINK("CHAR2",134,"00003F3F3F3F3C3C")
133 CALL LINK("CHAR2",135,"3C3C3F3F3F3F3C3C")
134 CALL LINK("CHAR2",136,"0000FCFCFCFC0000")
135 CALL LINK("CHAR2",137,"3C3CFCFCFCFC0000")
136 CALL LINK("CHAR2",138,"0000FFFFFFFF0000")
137 CALL LINK("CHAR2",139,"3C3CFFFFFFFF0000")
138 CALL LINK("CHAR2",140,"0000FCFCFCFC3C3C")
139 CALL LINK("CHAR2",141,"3C3CFCFCFCFC3C3C")
140 CALL LINK("CHAR2",142,"0000FFFFFFFF3C3C")
141 CALL LINK("CHAR2",143,"FFFFFFFFFFFFFFFF")
142 CALL LINK("CHAR2",144,"0000001818000000")
143 CALL LINK("CHAR2",152,"003C7E7E7E7E3C00")
144 CALL LINK("CHAR2",160,"000000FFFF000000")
145 REM --- sprite patterns (Screen1): Pac R/L/U/D 96/100/104/108, closed 112, ghost 116/120, eyes 124, fruit 128 ---
146 CALL CHAR(96,"00090F0F0F1F1F1F1F1F1F0F07000000000000E0F0F8E00000E0F8F0E0000000")
147 CALL CHAR(100,"000000070F1F070000071F0F070000000090F0F0F0F8F8F8F8F8F8F0E0000000")
148 CALL CHAR(104,"00121E1E1F3C383F3F3F3F1F0F000000000000E0F07838F0F0F0F0E0C0000000")
149 CALL CHAR(108,"00121E0F1F3F3F3F383C1F1E0F000000000000C0E0F0F0F03878F0E000000000")
150 CALL CHAR(112,"00090F070F1F1F1F1F1F1F0F07000000000000E0F0F8F8F8F8F8F8F0E0000000")
151 CALL CHAR(116,"000000071F36363F3F3F3F3F3612000000000080E0D8D8FCFCFCFCFCD8480000")
152 CALL CHAR(120,"000000071F36363F3F3F3F3F1B24000000000080E0D8D8FCFCFCFCFC6C900000")
153 CALL CHAR(124,"0000000000183C3C3C18000000000000000000000060F0F0F060000000000000")
154 CALL CHAR(128,"000000000103061C3E3F3F1E0C000000000060C0806030183C7E7E3C18000000")
155 CALL MAGNIFY(3)
156 DIM GX(4),GY(4),GD(4),OP(4),DS(4),RT(4),TM(4),GS(4),GC(4)
157 SX=121 :: SY=141 :: DD=0 :: PT=0 :: EC=0 :: LV=3
158 MZ=1 :: GOSUB 800
159 REM --- sprites: #1 Pac, #2-#5 ghosts; #6 roaming fruit created on demand ---
160 CALL SPRITE(#1,96,11,SY,SX,0,0)
161 CALL SPRITE(#2,116,9,77,121,0,0)
162 CALL SPRITE(#3,116,14,93,121,0,0)
163 CALL SPRITE(#4,116,8,93,105,0,0)
164 CALL SPRITE(#5,116,10,93,137,0,0)
165 GX(1)=121 :: GY(1)=77 :: GD(1)=4
166 GX(2)=121 :: GY(2)=93 :: GD(2)=4 :: GX(3)=105 :: GY(3)=93 :: GD(3)=4 :: GX(4)=137 :: GY(4)=93 :: GD(4)=4
167 RT(1)=0 :: RT(2)=10 :: RT(3)=30 :: RT(4)=60
168 CD=4 :: CALL KEY(0,K,S) :: CALL JOYST(1,JX,JY) :: IF K=83 OR JX<0 THEN CD=3
169 CALL LINK("FLICK")
170 TM(1)=0 :: TM(2)=150 :: TM(3)=300 :: TM(4)=450 :: FC=0
171 GC(1)=9 :: GC(2)=14 :: GC(3)=8 :: GC(4)=10 :: FT=0 :: EG=0 :: DG=0 :: FA=0 :: FN=0
172 GOSUB 708
173 GOSUB 710
190 REM ===== player movement via LOCATE (E/S/D/X or joystick; Q quits) =====
300 CALL KEY(0,K,S)
301 IF K=69 THEN DD=1
302 IF K=83 THEN DD=3
303 IF K=68 THEN DD=4
304 IF K=88 THEN DD=2
305 IF K=81 THEN 600
306 CALL JOYST(1,JX,JY)
307 IF JY>0 THEN DD=1
308 IF JY<0 THEN DD=2
309 IF JX<0 THEN DD=3
310 IF JX>0 THEN DD=4
311 IF CD=1 AND DD=2 THEN CD=2 :: GOTO 400
312 IF CD=2 AND DD=1 THEN CD=1 :: GOTO 400
313 IF CD=3 AND DD=4 THEN CD=4 :: GOTO 400
314 IF CD=4 AND DD=3 THEN CD=3 :: GOTO 400
315 AX=SX+3 :: AY=SY+3
316 IF AX-INT(AX/8)*8<>0 THEN 400
317 IF AY-INT(AY/8)*8<>0 THEN 400
320 C=INT((SX+11)/8) :: R=INT((SY+11)/8)
321 GOSUB 750
325 TR=R :: TC=C
326 IF DD=1 THEN TR=R-1
327 IF DD=2 THEN TR=R+1
328 IF DD=3 THEN TC=C-1
329 IF DD=4 THEN TC=C+1
330 GOSUB 700
331 IF WL=0 AND DD<>0 THEN CD=DD :: GOTO 400
335 TR=R :: TC=C
336 IF CD=1 THEN TR=R-1
337 IF CD=2 THEN TR=R+1
338 IF CD=3 THEN TC=C-1
339 IF CD=4 THEN TC=C+1
340 IF CD=0 THEN 400
341 GOSUB 700
342 IF WL=1 THEN CD=0
400 IF CD=1 THEN SY=SY-2
401 IF CD=2 THEN SY=SY+2
402 IF CD=3 THEN SX=SX-2
403 IF CD=4 THEN SX=SX+2
410 IF SY<>61 AND SY<>109 THEN 420
411 IF SX<13 THEN SX=229
412 IF SX>229 THEN SX=13
419 GW=116 :: IF FC-INT(FC/8)*8>=4 THEN GW=120
420 CALL LOCATE(#1,SY,SX)
421 PP=96 :: IF CD=1 THEN PP=104 ELSE IF CD=2 THEN PP=108 ELSE IF CD=3 THEN PP=100
422 PR=INT((SY+11)/8) :: PC=INT((SX+11)/8)
423 IF CD<>0 AND FC-INT(FC/8)*8>=4 THEN PP=112
424 CALL PATTERN(#1,PP)
425 FOR GI=1 TO 4 :: GOSUB 999 :: NEXT GI
426 FOR GI=1 TO 4
427 DX=ABS(SX-GX(GI)) :: DY=ABS(SY-GY(GI))
428 IF DX<=10 AND DY<=10 THEN GOSUB 780
429 NEXT GI
430 CALL LINK("DELAY",25)
431 IF FC<30000 THEN FC=FC+1
432 IF FT>0 THEN FT=FT-1
433 IF FA=1 THEN GOSUB 730
434 IF FA=1 THEN DX=ABS(SX-FX) :: DY=ABS(SY-FY) :: IF DX<=10 AND DY<=10 THEN GOSUB 770
440 GOTO 300
600 END
700 REM --- wall check: WL=1 if (TR,TC) is a wall tile (128-143) or the ghost-box/door ---
701 IF TC<1 OR TC>32 THEN WL=1 :: RETURN
702 IF TR<1 OR TR>24 THEN WL=1 :: RETURN
703 CALL GCHAR(TR,TC,G) :: WL=0
704 IF G>127 AND G<144 THEN WL=1
705 IF TR=12 AND TC>15 AND TC<18 THEN WL=1
706 IF TR=13 AND TC>13 AND TC<20 THEN WL=1
707 RETURN
708 CALL HCHAR(1,1,32,32) :: CALL HCHAR(2,1,32,32) :: DISPLAY AT(1,1):"MAZE";MZ;" SCORE";PT
709 DISPLAY AT(2,1):"DOTS";DT;" LIVES";LV :: RETURN
710 REM --- original arcade-style start jingle (sequential CALL SOUNDs block) ---
711 CALL SOUND(140,262,2)
712 CALL SOUND(140,330,2)
713 CALL SOUND(140,392,2)
714 CALL SOUND(180,523,2)
715 CALL SOUND(140,392,2)
716 CALL SOUND(160,523,2)
717 CALL SOUND(260,659,2)
718 CALL SOUND(340,523,2,659,4,784,6)
719 RETURN
720 REM --- spawn roaming fruit at a random tunnel mouth (#6 created on demand) ---
721 FN=FN+1 :: FA=1 :: FW=0 :: CALL LINK("IRND",2,PK) :: FY=61 :: IF PK=1 THEN FY=109
722 CALL LINK("IRND",2,PK) :: FX=13 :: FD=4 :: IF PK=1 THEN FX=229 :: FD=3
723 CALL SPRITE(#6,128,9,FY,FX,0,0)
724 RETURN
730 REM --- roaming fruit: wander (random turns), leave via a tunnel, despawn off-edge ---
731 FW=FW+1 :: BX=FX :: BY=FY :: BD=FD :: AX=BX+3 :: AY=BY+3
732 IF AX-INT(AX/8)*8<>0 OR AY-INT(AY/8)*8<>0 THEN 740
733 C=INT((BX+11)/8) :: R=INT((BY+11)/8) :: REV=0
734 IF BD=1 THEN REV=2 ELSE IF BD=2 THEN REV=1 ELSE IF BD=3 THEN REV=4 ELSE REV=3
735 NB=0
736 FOR DR=1 TO 4 :: TR=R :: TC=C :: IF DR=1 THEN TR=R-1 ELSE IF DR=2 THEN TR=R+1 ELSE IF DR=3 THEN TC=C-1 ELSE TC=C+1
737 GOSUB 760 :: IF WL=0 AND DR<>REV THEN NB=NB+1 :: DS(NB)=DR
738 NEXT DR :: IF NB=0 THEN BD=REV
739 IF NB>0 THEN CALL LINK("IRND",NB,PK) :: BD=DS(PK+1)
740 IF BD=1 THEN BY=BY-2 ELSE IF BD=2 THEN BY=BY+2 ELSE IF BD=3 THEN BX=BX-2 ELSE BX=BX+2
741 IF (BY=61 OR BY=109) AND (BX<13 OR BX>229) THEN CALL DELSPRITE(#6) :: FA=0 :: RETURN
742 FX=BX :: FY=BY :: FD=BD :: CALL LOCATE(#6,FY,FX)
743 RETURN
750 REM --- eat dot/pellet at (R,C): score, blip, update HUD, check win ---
751 CALL GCHAR(R,C,G) :: IF G<>144 AND G<>152 THEN 759
752 PT=PT+10 :: EC=EC+1 :: IF G=152 THEN PT=PT+40 :: GOSUB 774
753 CALL HCHAR(R,C,32) :: DT=DT-1 :: IF G=144 THEN CALL SOUND(40,1400,2)
754 GOSUB 708 :: IF FA=0 AND FN<2 AND (DT=154 OR DT=54) THEN GOSUB 720
755 IF DT>0 THEN 759
756 DISPLAY AT(13,10):"MAZE CLEARED!"
757 CALL LINK("DELAY",3000)
758 GOTO 600
759 RETURN
760 REM --- ghost wall check: as 700, but 706 dropped (pen open); door (765) blocked -- exit/return only via X=121 lane (1008-1011) ---
761 IF TC<1 OR TC>32 THEN WL=1 :: RETURN
762 IF TR<1 OR TR>24 THEN WL=1 :: RETURN
763 CALL GCHAR(TR,TC,G) :: WL=0
764 IF G>127 AND G<144 THEN WL=1
765 IF TR=12 AND TC>15 AND TC<18 THEN WL=1
766 RETURN
770 REM --- eat roaming fruit: bonus score, despawn ---
771 PT=PT+100 :: CALL DELSPRITE(#6) :: FA=0 :: GOSUB 708
772 CALL SOUND(300,523,2,659,4)
773 RETURN
774 REM --- power pellet eaten: frighten all non-eyes ghosts, reverse them, reset combo ---
775 FOR GI=1 TO 4
776 IF GS(GI)<>2 THEN GS(GI)=1 :: CALL COLOR(#(GI+1),5)
777 IF GS(GI)=1 AND GD(GI)=1 THEN GD(GI)=2 ELSE IF GS(GI)=1 AND GD(GI)=2 THEN GD(GI)=1
778 IF GS(GI)=1 AND GD(GI)=3 THEN GD(GI)=4 ELSE IF GS(GI)=1 AND GD(GI)=4 THEN GD(GI)=3
779 NEXT GI :: FT=300 :: EG=0 :: CALL SOUND(220,165,2,110,4) :: RETURN
780 REM --- Pac/ghost overlap: GS=0 caught, GS=1 eat ghost, GS=2 eyes (no effect) ---
781 IF GS(GI)=0 THEN GOSUB 1100
782 IF GS(GI)=1 THEN GOSUB 790
783 RETURN
790 REM --- eat frightened ghost GI: escalating score, become eyes ---
791 IF EG=0 THEN PT=PT+200
792 IF EG=1 THEN PT=PT+400
793 IF EG=2 THEN PT=PT+800
794 IF EG=3 THEN PT=PT+1600
795 EG=EG+1 :: GS(GI)=2 :: CALL COLOR(#(GI+1),16) :: CALL PATTERN(#(GI+1),124)
796 GOSUB 708
797 CALL SOUND(200,1800,3,2800,3)
798 RETURN
800 REM === DRAW MAZE MZ: set wall color, render to screen rows 3-24, count dots in DT ===
801 IF MZ=1 THEN RESTORE 9001 :: WC=14
810 CALL LINK("COLOR2",13,WC,1) :: CALL LINK("COLOR2",14,WC,1)
811 CALL LINK("COLOR2",15,16,1) :: CALL LINK("COLOR2",16,11,1)
812 CALL LINK("COLOR2",17,16,1)
815 DT=0
820 FOR MR=1 TO 22
821 READ A$
822 FOR I=1 TO 28
823 P$=SEG$(A$,I,1) :: CD=32
824 IF P$="." THEN CD=144 :: DT=DT+1
825 IF P$="O" THEN CD=152 :: DT=DT+1
826 IF P$="D" THEN CD=160
827 IF P$>="a" THEN CD=128+ASC(P$)-97
828 CALL HCHAR(MR+2,I+2,CD)
829 NEXT I
830 NEXT MR
831 RETURN
999 IF DG=GI AND GS(GI)<>0 THEN DG=0
1000 IF GS(GI)<>2 THEN CALL PATTERN(#(GI+1),GW)
1001 IF GS(GI)=1 AND FT=0 THEN GS(GI)=0 :: CALL COLOR(#(GI+1),GC(GI))
1002 IF GS(GI)=1 AND FT>0 AND FT<=90 THEN CL=5
1003 IF GS(GI)=1 AND FT>0 AND FT<=90 AND (FT-INT(FT/8)*8)<4 THEN CL=16
1004 IF GS(GI)=1 AND FT>0 AND FT<=90 THEN CALL COLOR(#(GI+1),CL)
1005 IF GS(GI)=1 AND (FC-INT(FC/2)*2)=0 THEN RETURN
1006 BX=GX(GI) :: BY=GY(GI) :: BD=GD(GI)
1007 RL=0 :: IF EC>=RT(GI) OR FC>=TM(GI) THEN RL=1
1008 IF BX=121 AND BY=93 AND (GS(GI)=2 OR (RL=1 AND GS(GI)=0 AND (DG=0 OR DG=GI))) THEN 1051
1009 IF RL=1 AND GS(GI)=0 AND BX=121 AND BY=77 AND BD=1 THEN CALL LINK("IRND",2,PK) :: BD=PK+3 :: DG=0 :: GOTO 1041
1010 IF GS(GI)=2 AND BX=121 AND BY=77 THEN BD=2 :: GOTO 1041
1011 IF GS(GI)=2 AND BX=117 AND BY=77 THEN BD=4 :: GOTO 1041
1012 AX=BX+3 :: AY=BY+3
1013 IF AX-INT(AX/8)*8<>0 THEN 1041
1014 IF AY-INT(AY/8)*8<>0 THEN 1041
1015 C=INT((BX+11)/8) :: R=INT((BY+11)/8) :: REV=0
1016 IF BD=1 THEN REV=2 ELSE IF BD=2 THEN REV=1
1017 IF BD=3 THEN REV=4 ELSE IF BD=4 THEN REV=3
1018 TGR=PR :: TGC=PC :: SG=1
1019 IF GS(GI)=1 THEN SG=-1
1020 IF GS(GI)=2 THEN TGR=11 :: TGC=16
1021 FOR DR=1 TO 4
1022 TR=R :: TC=C
1023 IF DR=1 THEN TR=R-1
1024 IF DR=2 THEN TR=R+1
1025 IF DR=3 THEN TC=C-1
1026 IF DR=4 THEN TC=C+1
1027 GOSUB 760
1028 OP(DR)=1-WL :: DS(DR)=SG*((TR-TGR)*(TR-TGR)+(TC-TGC)*(TC-TGC))
1029 NEXT DR
1030 CT=0 :: BS=9999
1031 FOR DR=1 TO 4
1032 IF OP(DR)=1 AND DR<>REV AND DS(DR)<BS THEN BS=DS(DR) :: BD=DR :: CT=1
1033 NEXT DR
1034 IF CT=0 AND REV>0 AND OP(REV)=1 THEN BD=REV :: CT=1
1035 IF CT=0 THEN BD=0
1041 IF BD=1 THEN BY=BY-2
1042 IF BD=2 THEN BY=BY+2
1043 IF BD=3 THEN BX=BX-2
1044 IF BD=4 THEN BX=BX+2
1045 IF BY<>61 AND BY<>109 THEN 1048
1046 IF BX<13 THEN BX=229
1047 IF BX>229 THEN BX=13
1048 GX(GI)=BX :: GY(GI)=BY :: GD(GI)=BD
1049 CALL LOCATE(#(GI+1),BY,BX)
1050 RETURN
1051 IF GS(GI)=2 THEN GS(GI)=0 :: CALL COLOR(#(GI+1),GC(GI)) :: CALL PATTERN(#(GI+1),116)
1052 DG=GI :: BD=1 :: GOTO 1041
1100 REM --- Pac-Man caught: lose a life; GAME OVER at 0, else respawn ---
1101 LV=LV-1 :: CALL HCHAR(1,1,32,32) :: CALL HCHAR(2,1,32,32) :: IF FA=1 THEN CALL DELSPRITE(#6) :: FA=0
1102 IF LV>0 THEN DISPLAY AT(1,11):"CAUGHT!" ELSE DISPLAY AT(1,10):"GAME OVER"
1103 CALL LINK("DELAY",2000)
1104 IF LV<=0 THEN 600
1105 FOR GI=1 TO 4 :: GS(GI)=0 :: GD(GI)=4 :: CALL COLOR(#(GI+1),GC(GI)) :: CALL PATTERN(#(GI+1),116) :: NEXT GI
1106 GX(1)=121 :: GY(1)=77 :: GX(2)=121 :: GY(2)=93 :: GX(3)=105 :: GY(3)=93 :: GX(4)=137 :: GY(4)=93
1107 FOR GI=1 TO 4 :: CALL LOCATE(#(GI+1),GY(GI),GX(GI)) :: NEXT GI
1108 SX=121 :: SY=141 :: DD=0 :: CD=4 :: CALL LOCATE(#1,SY,SX)
1109 FT=0 :: EG=0 :: EC=0 :: FC=0 :: DG=0 :: GOSUB 708
1110 RETURN
