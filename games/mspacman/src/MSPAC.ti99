100 REM ===========================================
101 REM  MS. PAC-MAN  (disk name: MSPAC)   -- STEP 4 (in progress)
102 REM  Data-driven maze (autotiled 4px walls) + per-maze color
103 REM  XB256 + XB compiler.  See DESIGN.md / repo CLAUDE.md
104 REM  Move: E/S/D/X or joystick.  Quit: Q
105 REM ===========================================
110 CALL LINK("SCRN2")
115 CALL SCREEN(2)
120 CALL CLEAR
125 REM --- 16 autotile wall tiles 128-143 (mask 0..15) ---
126 CALL LINK("CHAR2",128,"00003C3C3C3C0000")
127 CALL LINK("CHAR2",129,"3C3C3C3C3C3C0000")
128 CALL LINK("CHAR2",130,"00003F3F3F3F0000")
129 CALL LINK("CHAR2",131,"3C3C3F3F3F3F0000")
130 CALL LINK("CHAR2",132,"00003C3C3C3C3C3C")
131 CALL LINK("CHAR2",133,"3C3C3C3C3C3C3C3C")
132 CALL LINK("CHAR2",134,"00003F3F3F3F3C3C")
133 CALL LINK("CHAR2",135,"3C3C3F3F3F3F3C3C")
134 CALL LINK("CHAR2",136,"0000FCFCFCFC0000")
135 CALL LINK("CHAR2",137,"3C3CFCFCFCFC0000")
136 CALL LINK("CHAR2",138,"0000FFFFFFFF0000")
137 CALL LINK("CHAR2",139,"3C3CFFFFFFFF0000")
138 CALL LINK("CHAR2",140,"0000FCFCFCFC3C3C")
139 CALL LINK("CHAR2",141,"3C3CFCFCFCFC3C3C")
140 CALL LINK("CHAR2",142,"0000FFFFFFFF3C3C")
141 CALL LINK("CHAR2",143,"FFFFFFFFFFFFFFFF")
142 CALL LINK("CHAR2",144,"0000001818000000")
143 CALL LINK("CHAR2",152,"003C7E7E7E7E3C00")
144 CALL LINK("CHAR2",160,"000000FFFF000000")
145 REM --- sprite patterns: Ms Pac (96), ghost (100), fruit (104) ---
146 CALL CHAR(96,"0000071F3F3F3F3F3F3F3F3F1F0700000000E0F8FCF0C00000C0F0FCF8E00000")
147 CALL CHAR(100,"0000071F3F33333F3F3F3F3F3F3600000000E0F8FCCCCCFCFCFCFCFCFCD80000")
148 CALL CHAR(104,"0000000001070F1F1F1F0F0700000000000060C080C0E0F0F0F0E0C000000000")
150 CALL MAGNIFY(3)
151 DIM GX(4),GY(4),GD(4),OP(4),PD(4)
152 SX=121 :: SY=141 :: DD=0 :: PT=0
155 MZ=1 :: GOSUB 800
156 REM --- sprites: 3 ghosts in pen, Blinky on top, Pac + fruit in maze ---
157 CALL SPRITE(#1,96,11,SY,SX,0,0)
158 CALL SPRITE(#2,100,9,77,121,0,0)
159 CALL SPRITE(#3,100,14,93,105,0,0)
160 CALL SPRITE(#4,100,8,93,121,0,0)
161 CALL SPRITE(#5,100,10,93,137,0,0)
162 CALL SPRITE(#6,104,9,109,121,0,0)
163 GX(1)=121 :: GY(1)=77 :: GD(1)=4
164 GX(2)=105 :: GY(2)=93 :: GD(2)=4 :: GX(3)=121 :: GY(3)=93 :: GD(3)=4 :: GX(4)=137 :: GY(4)=93 :: GD(4)=4
166 CD=4 :: CALL KEY(0,K,S) :: CALL JOYST(1,JX,JY) :: IF K=83 OR JX<0 THEN CD=3
170 DISPLAY AT(1,1):"MAZE";MZ;" DOTS";DT;" SCORE";PT
190 REM ===== player movement via LOCATE (E/S/D/X or joystick; Q quits) =====
300 CALL KEY(0,K,S)
301 IF K=69 THEN DD=1
302 IF K=83 THEN DD=3
303 IF K=68 THEN DD=4
304 IF K=88 THEN DD=2
305 IF K=81 THEN 600
306 CALL JOYST(1,JX,JY)
307 IF JY>0 THEN DD=1
308 IF JY<0 THEN DD=2
309 IF JX<0 THEN DD=3
310 IF JX>0 THEN DD=4
315 AX=SX+3 :: AY=SY+3
316 IF AX-INT(AX/8)*8<>0 THEN 400
317 IF AY-INT(AY/8)*8<>0 THEN 400
320 C=INT((SX+11)/8) :: R=INT((SY+11)/8)
321 GOSUB 750
325 TR=R :: TC=C
326 IF DD=1 THEN TR=R-1
327 IF DD=2 THEN TR=R+1
328 IF DD=3 THEN TC=C-1
329 IF DD=4 THEN TC=C+1
330 GOSUB 700
331 IF WL=0 AND DD<>0 THEN CD=DD :: GOTO 400
335 TR=R :: TC=C
336 IF CD=1 THEN TR=R-1
337 IF CD=2 THEN TR=R+1
338 IF CD=3 THEN TC=C-1
339 IF CD=4 THEN TC=C+1
340 IF CD=0 THEN 400
341 GOSUB 700
342 IF WL=1 THEN CD=0
400 IF CD=1 THEN SY=SY-2
401 IF CD=2 THEN SY=SY+2
402 IF CD=3 THEN SX=SX-2
403 IF CD=4 THEN SX=SX+2
410 IF SY<>61 AND SY<>109 THEN 420
411 IF SX<13 THEN SX=229
412 IF SX>229 THEN SX=13
420 CALL LOCATE(#1,SY,SX)
425 FOR GI=1 TO 4 :: GOSUB 710 :: NEXT GI
430 CALL LINK("DELAY",25)
440 GOTO 300
600 END
700 REM --- wall check: WL=1 if (TR,TC) is a wall tile (128-143) or the ghost-box/door ---
701 IF TC<1 OR TC>32 THEN WL=1 :: RETURN
702 IF TR<1 OR TR>24 THEN WL=1 :: RETURN
703 CALL GCHAR(TR,TC,G) :: WL=0
704 IF G>127 AND G<144 THEN WL=1
705 IF TR=12 AND TC>15 AND TC<18 THEN WL=1
706 IF TR=13 AND TC>13 AND TC<20 THEN WL=1
707 RETURN
710 REM --- ghost GI: wander (random turn at open cells, reverse at dead ends) ---
711 BX=GX(GI) :: BY=GY(GI) :: BD=GD(GI)
712 AX=BX+3 :: AY=BY+3
713 IF AX-INT(AX/8)*8<>0 THEN 740
714 IF AY-INT(AY/8)*8<>0 THEN 740
715 C=INT((BX+11)/8) :: R=INT((BY+11)/8)
716 REV=0
717 IF BD=1 THEN REV=2
718 IF BD=2 THEN REV=1
719 IF BD=3 THEN REV=4
720 IF BD=4 THEN REV=3
721 FOR DR=1 TO 4
722 TR=R :: TC=C
723 IF DR=1 THEN TR=R-1
724 IF DR=2 THEN TR=R+1
725 IF DR=3 THEN TC=C-1
726 IF DR=4 THEN TC=C+1
727 GOSUB 760
728 OP(DR)=1-WL
729 NEXT DR
730 CT=0
731 FOR DR=1 TO 4
732 IF OP(DR)=1 AND DR<>REV THEN CT=CT+1 :: PD(CT)=DR
733 NEXT DR
734 IF CT=0 AND REV>0 AND OP(REV)=1 THEN CT=1 :: PD(1)=REV
735 IF CT=0 THEN BD=0 :: GOTO 740
736 CALL LINK("IRND",CT,PK) :: BD=PD(PK+1)
740 IF BD=1 THEN BY=BY-2
741 IF BD=2 THEN BY=BY+2
742 IF BD=3 THEN BX=BX-2
743 IF BD=4 THEN BX=BX+2
744 IF BY<>61 AND BY<>109 THEN 747
745 IF BX<13 THEN BX=229
746 IF BX>229 THEN BX=13
747 GX(GI)=BX :: GY(GI)=BY :: GD(GI)=BD
748 CALL LOCATE(#(GI+1),BY,BX)
749 RETURN
750 REM --- eat dot/pellet at (R,C): score, blip, update HUD, check win ---
751 CALL GCHAR(R,C,G) :: IF G<>144 AND G<>152 THEN 759
752 PT=PT+10 :: IF G=152 THEN PT=PT+40
753 CALL HCHAR(R,C,32) :: DT=DT-1 :: CALL SOUND(40,1400,2)
754 CALL HCHAR(1,1,32,32) :: DISPLAY AT(1,1):"MAZE";MZ;" DOTS";DT;" SCORE";PT
755 IF DT>0 THEN 759
756 DISPLAY AT(13,10):"MAZE CLEARED!"
757 CALL LINK("DELAY",3000)
758 GOTO 600
759 RETURN
760 REM --- ghost wall check: as 700, but ghosts may sit in the pen interior (706 is player-only) ---
761 IF TC<1 OR TC>32 THEN WL=1 :: RETURN
762 IF TR<1 OR TR>24 THEN WL=1 :: RETURN
763 CALL GCHAR(TR,TC,G) :: WL=0
764 IF G>127 AND G<144 THEN WL=1
765 IF TR=12 AND TC>15 AND TC<18 THEN WL=1
766 RETURN
800 REM === DRAW MAZE MZ: set wall color, render to screen rows 3-24, count dots in DT ===
801 IF MZ=1 THEN RESTORE 9001 :: WC=14
810 CALL LINK("COLOR2",13,WC,1) :: CALL LINK("COLOR2",14,WC,1)
811 CALL LINK("COLOR2",15,16,1) :: CALL LINK("COLOR2",16,11,1)
812 CALL LINK("COLOR2",17,16,1)
815 DT=0
820 FOR MR=1 TO 22
821 READ A$
822 FOR I=1 TO 28
823 P$=SEG$(A$,I,1) :: CD=32
824 IF P$="." THEN CD=144 :: DT=DT+1
825 IF P$="O" THEN CD=152 :: DT=DT+1
826 IF P$="D" THEN CD=160
827 IF P$>="a" THEN CD=128+ASC(P$)-97
828 CALL HCHAR(MR+2,I+2,CD)
829 NEXT I
830 NEXT MR
831 RETURN
