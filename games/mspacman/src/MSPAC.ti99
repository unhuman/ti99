1161 FFC=128 :: FFL=9 :: FFP=10
1162 IF LE=1 THEN CALL CHAR(128,"00000000000103070F1F1F0F0700000000000060C0800080C0E0E0C080000000")
1163 IF LE=2 THEN CALL CHAR(128,"0000000F1F1F1F0F0F07030000000000000000C0E0E0E0C0C080000000000000") :: FFP=20
1164 IF LE=3 THEN CALL CHAR(128,"0000030F1F3F3F3F1F0F000000000000000000C0E0F0F0F0E0C0000000000000") :: FFL=11 :: FFP=50
1165 IF LE=4 THEN CALL CHAR(128,"0000183C2728273C180F070000000000000060F0905090F060C0800000000000") :: FFL=7 :: FFP=70
1166 IF LE=5 THEN CALL CHAR(128,"000001061B3F3F3F1F0F00000000000000000000C0F0F0F0E0C0000000000000") :: FFL=3 :: FFP=100
1167 IF LE=6 THEN CALL CHAR(128,"00000306070F1F3F3F3F1F0F00000000000000000080C0C0C0C0800000000000") :: FFL=13 :: FFP=200
1168 IF LE>=7 THEN CALL CHAR(128,"00000001030707070703010000000000000060E0C080000080C0E06000000000") :: FFL=12 :: FFP=500
1169 RETURN
1170 REM --- scatter<->chase switch: toggle mode, reset timer, reverse maze (non-pen) chase ghosts ---
1171 MO=1-MO :: MT=800 :: IF MO=0 THEN MT=280
1172 FOR J=1 TO 4
1173 IF GS(J)=0 AND GX(J)<>121 AND GD(J)=1 THEN GD(J)=2 ELSE IF GS(J)=0 AND GX(J)<>121 AND GD(J)=2 THEN GD(J)=1
1174 IF GS(J)=0 AND GX(J)<>121 AND GD(J)=3 THEN GD(J)=4 ELSE IF GS(J)=0 AND GX(J)<>121 AND GD(J)=4 THEN GD(J)=3
1175 NEXT J
1176 RETURN
1180 REM --- target (TGR,TGC)+sign SG for ghost GI: state, then scatter(MO=0)/chase personality ---
1181 SG=1 :: TGR=PR :: TGC=PC
1182 IF GS(GI)=1 THEN SG=-1 :: RETURN
1183 IF GS(GI)=2 THEN TGR=11 :: TGC=16 :: RETURN
1184 IF MO=0 THEN TGR=SR(GI) :: TGC=SC(GI) :: RETURN
1185 IF GI=2 AND CD=1 THEN TGR=PR-4
1186 IF GI=2 AND CD=2 THEN TGR=PR+4
1187 IF GI=2 AND CD=3 THEN TGC=PC-4
1188 IF GI=2 AND CD=4 THEN TGC=PC+4
1189 IF GI=4 AND (R-PR)*(R-PR)+(C-PC)*(C-PC)<=64 THEN TGR=SR(4) :: TGC=SC(4)
1190 IF GI<>3 THEN RETURN
1191 R2=PR :: C2=PC
1192 IF CD=1 THEN R2=PR-2 ELSE IF CD=2 THEN R2=PR+2 ELSE IF CD=3 THEN C2=PC-2 ELSE C2=PC+2
1193 TGR=2*R2-INT((GY(1)+11)/8) :: TGC=2*C2-INT((GX(1)+11)/8)
1194 RETURN
