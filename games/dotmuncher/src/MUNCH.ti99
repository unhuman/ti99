100 REM ===========================================
101 REM  DOT MUNCHER   (disk name: MUNCH)
102 REM  XB256 + XB compiler.  See repo CLAUDE.md.
103 REM  Controls: E=up  S=left  D=right  X=down
104 REM ===========================================
105 REM ---- INIT ----
110 CALL LINK("SCRN2")
120 CALL SCREEN(2)
130 CALL LINK("CHAR2",96,"FFFFFFFFFFFFFFFF")
140 CALL LINK("CHAR2",42,"0000001818000000")
150 CALL LINK("CHAR2",128,"3C7EFCF8F8FC7E3C")
160 CALL LINK("COLOR2",9,6,1)
170 CALL LINK("COLOR2",2,16,1)
180 CALL LINK("COLOR2",13,12,1)
190 CALL CLEAR
200 SC=0 :: DT=0 :: PR=4 :: PC=11
210 REM ---- draw maze: box rows 3..12, cols 10..23 ----
220 CALL HCHAR(3,10,96,14)
230 CALL HCHAR(12,10,96,14)
240 CALL VCHAR(3,10,96,10)
250 CALL VCHAR(3,23,96,10)
260 REM interior divider (row 8, cols 13..20)
270 CALL HCHAR(8,13,96,8)
280 REM place player first so its cell is not filled with a dot
290 CALL HCHAR(PR,PC,128)
300 REM ---- fill open interior cells with dots and count them ----
310 FOR R=4 TO 11
320 FOR C=11 TO 22
330 CALL GCHAR(R,C,G)
340 IF G=32 THEN CALL HCHAR(R,C,42) :: DT=DT+1
350 NEXT C
360 NEXT R
400 DISPLAY AT(1,1):"SCORE";SC;" DOTS";DT;"   "
410 REM ===== MAIN LOOP =====
500 CALL KEY(0,K,S)
510 IF S=0 THEN 600
520 NR=PR :: NC=PC
530 IF K=69 THEN NR=PR-1
540 IF K=83 THEN NC=PC-1
550 IF K=68 THEN NC=PC+1
560 IF K=88 THEN NR=PR+1
570 CALL GCHAR(NR,NC,G)
580 IF G=96 THEN 600
585 CALL HCHAR(PR,PC,32) :: PR=NR :: PC=NC
590 IF G=42 THEN SC=SC+10 :: DT=DT-1 :: CALL SOUND(20,880,2) :: DISPLAY AT(1,1):"SCORE";SC;" DOTS";DT;"   "
595 CALL HCHAR(PR,PC,128)
600 IF DT=0 THEN 700
610 CALL LINK("DELAY",40)
620 GOTO 500
700 REM ===== WIN =====
710 CALL SOUND(150,523,2) :: CALL SOUND(150,659,2) :: CALL SOUND(300,784,2)
720 DISPLAY AT(14,9):"YOU WIN!"
730 DISPLAY AT(16,5):"PRESS ANY KEY TO END"
740 CALL KEY(0,K,S) :: IF S<1 THEN 740
750 END
